// Next-CMS: Headless CMS - Prisma Schema
// Dynamic content types, documents stored as JSON, relations in separate table

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============ Content-Type Builder (Schema Registry) ============

model ContentType {
  id                     String   @id @default(cuid())
  name                   String   // Display name e.g. "Article"
  singularId             String   @unique // API ID singular e.g. "article"
  pluralId               String   @unique // API ID plural e.g. "articles"
  kind                   String   // "collectionType" | "singleType"
  description            String?
  draftPublish           Boolean  @default(false)
  defaultPublicationState String   @default("draft") // "draft" | "published" - default when creating new entry
  i18n                   Boolean  @default(false)
  attributes             String   // JSON: array of attribute definitions
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  documents Document[]
}

model Component {
  id          String   @id @default(cuid())
  name        String   // Display name
  category   String   // e.g. "shared", "blog"
  icon        String?
  attributes  String   // JSON: array of attribute definitions
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============ Content (Documents) ============
// All collection/single type entries stored here. Data is JSON; relations resolved via DocumentRelation.

model Document {
  id            String    @id @default(cuid())
  documentId    String    @unique // Public API identifier (cuid)
  contentTypeId String
  contentType   ContentType @relation(fields: [contentTypeId], references: [id], onDelete: Cascade)
  data          String    // JSON: all scalar + component + media refs (ids)
  publishedAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  locale        String    @default("en")

  // Relations where this doc is the "left" (owner) side
  relationsFrom DocumentRelation[] @relation("FromDocument")
  relationsTo   DocumentRelation[] @relation("ToDocument")
}

model DocumentRelation {
  id             String   @id @default(cuid())
  fieldName      String   // attribute name on the owner content type
  order          Int      @default(0)
  fromDocumentId String
  fromDocument   Document @relation("FromDocument", fields: [fromDocumentId], references: [id], onDelete: Cascade)
  toDocumentId   String
  toDocument     Document @relation("ToDocument", fields: [toDocumentId], references: [id], onDelete: Cascade)

  @@unique([fromDocumentId, fieldName, toDocumentId])
  @@index([fromDocumentId, fieldName])
  @@index([toDocumentId])
}

// ============ Media Library ============

model MediaFolder {
  id        String   @id @default(cuid())
  name      String   // display name e.g. "Banners"
  path      String   @unique // path slug e.g. "banners" or "blog/2025"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Media {
  id              String   @id @default(cuid())
  name            String
  alternativeText String?
  caption         String?
  hash            String   // file name on disk (unique within folder)
  folder          String   @default("") // e.g. "2025/02" or "banners"
  ext             String   // .jpg, .png
  mime            String
  size            Float    // bytes
  url             String   // public URL or /api/upload/files/...
  storage         String   @default("local") // "local" | "s3"
  providerKey     String?  // object key (S3) or folder/hash path (local)
  width           Int?
  height          Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ============ Auth & Permissions () ============

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  username  String?  @unique
  password  String   // bcrypt hash
  firstname String?
  lastname  String?
  blocked   Boolean  @default(false)
  roleId    String?
  role      Role?    @relation(fields: [roleId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  type        String?  // "authenticated" | "public" | "custom"
  users       User[]
  permissions Permission[]
}

model Permission {
  id       String @id @default(cuid())
  action   String // e.g. "api::article.article.find", "api::article.article.create"
  roleId   String
  role     Role   @relation(fields: [roleId], references: [id], onDelete: Cascade)
  enabled  Boolean @default(true)

  @@unique([action, roleId])
  @@index([roleId])
}

// ============ Webhooks (outbound + inbound) ============

model Webhook {
  id            String   @id @default(cuid())
  name          String
  direction     String   // "outbound" | "inbound"
  url           String?  // target URL (outbound only)
  secret        String?  // HMAC signing (outbound) or verification (inbound)
  enabled       Boolean  @default(true)
  events        String   // JSON: string[] e.g. ["entry.create","entry.update"]
  contentTypes  String?  // JSON: pluralId[] filter; null/[] = all content types
  headers       String?  // JSON: Record<string, string> extra outbound headers
  actions       String?  // JSON: inbound action config (verify + update document)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  deliveries WebhookDelivery[]
}

model WebhookDelivery {
  id           String   @id @default(cuid())
  webhookId    String
  webhook      Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  event        String
  direction    String   // "outbound" | "inbound"
  success      Boolean  @default(false)
  statusCode   Int?
  durationMs   Int?
  error        String?
  requestBody  String?
  responseBody String?
  createdAt    DateTime @default(now())

  @@index([webhookId, createdAt])
}

// ============ Plugins (ZIP install, manifest-driven) ============

model Plugin {
  id          String   @id @default(cuid())
  pluginId    String   @unique // manifest id e.g. "mail-sender"
  name        String
  version     String
  description String?
  author      String?
  enabled     Boolean  @default(true)
  manifest    String   // full plugin.json
  installPath String   // relative dir under PLUGINS_DIR
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  data PluginData[]
}

model PluginData {
  id        String   @id @default(cuid())
  pluginId  String
  plugin    Plugin   @relation(fields: [pluginId], references: [id], onDelete: Cascade)
  collection String  @default("default") // e.g. "templates", "settings"
  key       String
  value     String   // JSON
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([pluginId, collection, key])
  @@index([pluginId, collection])
}

// ============ Content-Type Templates (pre-defined schemas) ============

model ContentTypeTemplate {
  id          String   @id @default(cuid())
  name        String   // e.g. "Blog Post"
  description String?
  schema      String   // JSON: { kind, attributes } to apply when creating from template
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
