DATABASE_URL="file:./dev.db"
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
NEXTAUTH_URL="http://localhost:3000"
# HOSTNAME="0.0.0.0"
# PORT=4000

# Media storage: local | s3 (default local)
UPLOAD_STORAGE=local

# Local disk storage
UPLOAD_DIR="./uploads"
# UPLOAD_DISABLE_LOCAL=true
# UPLOAD_MAX_BYTES=10485760

# UPLOAD_DIR=D:\data\next-cms-uploads
# # or on Linux: UPLOAD_DIR=/var/lib/next-cms/uploads
# JWT_SECRET=your-long-random-secret-at-least-32-chars

# Amazon S3 (or MinIO / compatible)
# AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_BUCKET=my-cms-media
# S3_PREFIX=media
# Public CDN/base URL (if set, files are linked directly; otherwise served via /api/upload/files/...)
# S3_PUBLIC_BASE_URL=https://my-bucket.s3.amazonaws.com
# MinIO example:
# S3_ENDPOINT=http://127.0.0.1:9000
# S3_FORCE_PATH_STYLE=true

